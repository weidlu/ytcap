{
  "name": "ytcap",
  "version": "0.1.0",
  "description": "CLI for fetching YouTube video metadata and transcripts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weidlu/ytcap.git"
  },
  "bugs": {
    "url": "https://github.com/weidlu/ytcap/issues"
  },
  "homepage": "https://github.com/weidlu/ytcap#readme",
  "keywords": [
    "youtube",
    "transcript",
    "subtitle",
    "cli",
    "yt-dlp"
  ],
  "type": "module",
  "bin": {
    "ytcap": "dist/src/index.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json && node ./scripts/postbuild.mjs",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "check": "npm run build && npm test",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
